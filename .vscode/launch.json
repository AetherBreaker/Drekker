{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Attach Debugger to Textual",
            "type": "debugpy",
            "request": "attach",
            "justMyCode": false,
            "listen": {
                "host": "127.0.0.1",
                "port": 5678
            }
        },
        {
            "name": "Launch Textual in WT",
            "type": "PowerShell",
            "request": "launch",
            "script": "ping",
            "preLaunchTask": "Textual Debug: Launch All",
            "internalConsoleOptions": "neverOpen",
            "postDebugTask": "Close Windows Terminal Windows",
            "presentation": {
                "hidden": true
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug Textual",
            "configurations": [
                "Attach Debugger to Textual",
                "Launch Textual in WT"
            ],
            "stopAll": true
        }
    ]
}

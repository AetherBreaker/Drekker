{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Textual Console",
            "type": "shell",
            "command": "& ${workspaceFolder}\\.venv\\Scripts\\Activate.ps1; textual console",
            "runOptions": {
                "instanceLimit": 1,
                "instancePolicy": "terminateOldest"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": true
        },
        {
            "label": "Launch Textual in Dev Mode",
            "type": "shell",
            "command": "wt.exe",
            "args": [
                "-d",
                "${workspaceFolder}",
                "powershell",
                "-NoExit",
                "-Command",
                "& .\\.venv\\Scripts\\Activate.ps1\\; textual run src/drekker/__main__.py --dev"
            ],
            "runOptions": {
                "instanceLimit": 1,
                "instancePolicy": "terminateOldest"
            },
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/src",
                    "PYTHONPYCACHEPREFIX": "${workspaceFolder}/PYCACHE",
                    "PYTHONUNBUFFERED": "1",
                    "TEXTUAL": "devtools"
                }
            },
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": true
        },
        {
            "label": "Textual Debug: Launch All",
            "dependsOn": ["Textual Console", "Launch Textual in Dev Mode"],
            "dependsOrder": "parallel",
            "isBackground": true
        }
    ]
}

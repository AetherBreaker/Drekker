{
  "$defs": {
    "Note": {
      "properties": {
        "target": {
          "oneOf": [
            {
              "const": "APPEARANCE",
              "description": "Sends note to the appearance section of the character sheet."
            }
          ],
          "title": "Target"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "target",
        "content"
      ],
      "title": "Note",
      "type": "object"
    },
    "Quality": {
      "description": "Base model for quality datapacks.",
      "else": {
        "properties": {
          "subcategory": {
            "type": "null"
          }
        }
      },
      "if": {
        "properties": {
          "category": {
            "const": "SURGE"
          }
        }
      },
      "properties": {
        "rewards_edge": {
          "anyOf": [
            {
              "$ref": "#/$defs/RewardsEdge"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "notes": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Note"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "kind": {
          "enum": [
            "POSITIVE",
            "NEGATIVE"
          ],
          "title": "QualityKind",
          "type": "string"
        },
        "category": {
          "oneOf": [
            {
              "const": "ADEPT_WAYS",
              "description": "Street Wyrd"
            },
            {
              "const": "CHARACTER_TRAITS",
              "description": "Shadow Cast"
            },
            {
              "const": "DRAKE",
              "description": "Lofwyr's Legions"
            },
            {
              "const": "HMHVV_INFECTED",
              "description": "Companion"
            },
            {
              "const": "LIFESTYLE"
            },
            {
              "const": "MARTIAL_ART"
            },
            {
              "const": "SURGE",
              "description": "Companion"
            },
            {
              "const": "REGULAR",
              "description": "Regular Qualities"
            },
            {
              "const": "SHIFTER",
              "description": "Shifter Qualities"
            },
            {
              "const": "STREAMS",
              "description": "Technomancer Streams - Hack N Slash"
            },
            {
              "const": "TRANSGENIC",
              "description": "Body Shop"
            },
            {
              "const": "VIRTUAL_LIFE",
              "description": "AI/EI - Hack N Slash"
            }
          ],
          "title": "Category"
        },
        "subcategory": {
          "anyOf": [
            {
              "oneOf": [
                {
                  "const": "ANIMAL_PELAGE",
                  "description": "Animal Pelage"
                },
                {
                  "const": "BENEFICIAL_SECRETIONS",
                  "description": "Beneficial Secretions"
                },
                {
                  "const": "COMPLEX_TRAITS",
                  "description": "Complex Traits"
                },
                {
                  "const": "DERMAL_ALTERATION",
                  "description": "Dermal Alterations"
                },
                {
                  "const": "METAGENIC_SENSES",
                  "description": "Metagenic Senses"
                },
                {
                  "const": "METAGENIC_MORPHISMS",
                  "description": "Metagenic Morphisms"
                },
                {
                  "const": "AHD",
                  "description": "Aural Helix Dysmorphia (AHD)"
                },
                {
                  "const": "BIOLOGICAL_DYSMORPHIA",
                  "description": "Biological Dysmorphia"
                },
                {
                  "const": "METAGENIC_ANOMALIES",
                  "description": "Metagenic Anomalies"
                },
                {
                  "const": "METAGENIC_DEFECTS",
                  "description": "Metagenic Defects"
                },
                {
                  "const": "METAGENIC_THROWBACKS",
                  "description": "Metagenic Throwbacks"
                },
                {
                  "const": "NEUROPATHIC_ADJUSTED_STATES",
                  "description": "Neuropathic Adjusted States (NAS)"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subcategory"
        },
        "karma": {
          "title": "Karma",
          "type": "integer"
        },
        "source": {
          "description": "Enum for sources that can be used in the datapack.",
          "enum": [
            "Sixth World Companion",
            "Core Rulebook (Any Edition)",
            "Core Rulebook (Berlin Edition)",
            "Core Rulebook (Hong Kong Edition)",
            "Core Rulebook (Seattle Edition)",
            "Hack'n Slash",
            "No Future",
            "Firing Squad"
          ],
          "title": "Sources",
          "type": "string"
        },
        "page_number": {
          "title": "Page Number",
          "type": "integer"
        },
        "sub_options": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/QualitySubOption"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sub Options"
        }
      },
      "required": [
        "name",
        "kind",
        "category",
        "karma",
        "source",
        "page_number"
      ],
      "then": {
        "properties": {
          "subcategory": {
            "oneOf": [
              {
                "const": "ANIMAL_PELAGE",
                "description": "Animal Pelage"
              },
              {
                "const": "BENEFICIAL_SECRETIONS",
                "description": "Beneficial Secretions"
              },
              {
                "const": "COMPLEX_TRAITS",
                "description": "Complex Traits"
              },
              {
                "const": "DERMAL_ALTERATION",
                "description": "Dermal Alterations"
              },
              {
                "const": "METAGENIC_SENSES",
                "description": "Metagenic Senses"
              },
              {
                "const": "METAGENIC_MORPHISMS",
                "description": "Metagenic Morphisms"
              },
              {
                "const": "AHD",
                "description": "Aural Helix Dysmorphia (AHD)"
              },
              {
                "const": "BIOLOGICAL_DYSMORPHIA",
                "description": "Biological Dysmorphia"
              },
              {
                "const": "METAGENIC_ANOMALIES",
                "description": "Metagenic Anomalies"
              },
              {
                "const": "METAGENIC_DEFECTS",
                "description": "Metagenic Defects"
              },
              {
                "const": "METAGENIC_THROWBACKS",
                "description": "Metagenic Throwbacks"
              },
              {
                "const": "NEUROPATHIC_ADJUSTED_STATES",
                "description": "Neuropathic Adjusted States (NAS)"
              }
            ]
          }
        }
      },
      "title": "Quality",
      "type": "object"
    },
    "QualitySubOption": {
      "description": "Model for quality sub-options.",
      "properties": {
        "rewards_edge": {
          "anyOf": [
            {
              "$ref": "#/$defs/RewardsEdge"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "notes": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Note"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "source": {
          "anyOf": [
            {
              "description": "Enum for sources that can be used in the datapack.",
              "enum": [
                "Sixth World Companion",
                "Core Rulebook (Any Edition)",
                "Core Rulebook (Berlin Edition)",
                "Core Rulebook (Hong Kong Edition)",
                "Core Rulebook (Seattle Edition)",
                "Hack'n Slash",
                "No Future",
                "Firing Squad"
              ],
              "title": "Sources",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "page_number": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page Number"
        }
      },
      "required": [
        "name"
      ],
      "title": "QualitySubOption",
      "type": "object"
    },
    "RewardsEdge": {
      "properties": {
        "rewards_on": {
          "oneOf": [
            {
              "const": "ON_LOGIC_TEST",
              "description": "Actions linked to this trigger are performed when a logic test is made."
            }
          ],
          "title": "Rewards On"
        },
        "reward_amount": {
          "default": 1,
          "title": "Reward Amount",
          "type": "integer"
        },
        "temporary": {
          "default": false,
          "title": "Temporary",
          "type": "boolean"
        },
        "situational": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Situational"
        },
        "extra": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extra"
        }
      },
      "required": [
        "rewards_on"
      ],
      "title": "RewardsEdge",
      "type": "object"
    }
  },
  "properties": {
    "qualities": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Quality"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "A list of qualities that the datapack has.\n    This can be used to determine which features to enable or disable when loading the datapack.",
      "title": "Qualities"
    }
  },
  "title": "DatapackSerializer",
  "type": "object"
}